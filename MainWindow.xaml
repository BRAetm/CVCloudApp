<Window x:Class="LabsVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LabsVision.UI.Views"
        xmlns:controls="clr-namespace:LabsVision.UI.Controls"
        xmlns:converters="clr-namespace:LabsVision.UI.Converters"
        xmlns:models="clr-namespace:LabsVision.Models"
        Title="Labs Vision"
        Background="#FF0A0E14"
        Foreground="#FFE6EDF3"
        MinWidth="1280" MinHeight="760"
        Width="1560" Height="900"
        WindowState="Maximized"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <!-- ============================================================ -->
    <!--                    DESIGN TOKENS / RESOURCES                  -->
    <!-- ============================================================ -->
    <Window.Resources>

        <!-- Editorial command-deck palette -->
        <SolidColorBrush x:Key="Bg"          Color="#FF0A0E14"/>
        <SolidColorBrush x:Key="Surface"     Color="#FF11161D"/>
        <SolidColorBrush x:Key="SurfaceAlt"  Color="#FF0E131A"/>
        <SolidColorBrush x:Key="SurfaceLift" Color="#FF161C25"/>
        <SolidColorBrush x:Key="Hairline"    Color="#FF1F2630"/>
        <SolidColorBrush x:Key="Text"        Color="#FFE6EDF3"/>
        <SolidColorBrush x:Key="Muted"       Color="#FF6B7785"/>
        <SolidColorBrush x:Key="Faint"       Color="#FF3B4452"/>
        <SolidColorBrush x:Key="Accent"      Color="#FF2563EB"/>
        <SolidColorBrush x:Key="AccentDim"   Color="#FF1E40AF"/>
        <SolidColorBrush x:Key="Warn"        Color="#FFFFB454"/>
        <SolidColorBrush x:Key="Action"      Color="#FF4D9DFF"/>
        <SolidColorBrush x:Key="Danger"      Color="#FFFF5C5C"/>

        <FontFamily x:Key="Mono">Cascadia Mono, Consolas, Courier New</FontFamily>
        <FontFamily x:Key="Display">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>
        <FontFamily x:Key="Body">Segoe UI Variable Text, Segoe UI, Arial</FontFamily>

        <!-- Override system popup colors so dropdowns look right -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"                       Color="#FF11161D"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"                   Color="#FFE6EDF3"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                    Color="#FF1F2630"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                Color="#FF2563EB"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"   Color="#FF161C25"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFE6EDF3"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"                         Color="#FF11161D"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"                     Color="#FFE6EDF3"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}"                Color="#FF1F2630"/>

        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StatusToStringConverter   x:Key="StatusToStr"/>

        <!-- ============== TYPOGRAPHY HELPERS ============== -->
        <Style x:Key="Eyebrow" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <!-- ============== BUTTON: GHOST ============== -->
        <Style x:Key="Ghost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Text}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceLift}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1D2530"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============== BUTTON: ACCENT ============== -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource Ghost}">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3B82F6"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============== ICON / SQUARE BUTTON ============== -->
        <Style x:Key="Icon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceLift}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============== MENU ============== -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="{StaticResource Body}"/>
        </Style>

        <!-- ============== COMBOBOX ============== -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceLift}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF1A2030"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============== SCROLLBAR (slim) ============== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Hairline}"/>
        </Style>

        <!-- ============== LIST ITEM (plain) ============== -->
        <Style x:Key="PlainListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============== SCRIPT FILE ROW ============== -->
        <Style x:Key="ScriptItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Hairline}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceLift}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF152035"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============== PANEL HEADER ============== -->
        <Style x:Key="PanelHeader" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,11"/>
        </Style>

    </Window.Resources>

    <!-- ============================================================ -->
    <!--                          ROOT LAYOUT                          -->
    <!-- ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Menu strip -->
            <RowDefinition Height="Auto"/>   <!-- Command bar -->
            <RowDefinition Height="*"/>      <!-- Main 3-column layout -->
            <RowDefinition Height="Auto"/>   <!-- Status strip -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!--                  ROW 0 — MENU STRIP                           -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Hairline}"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent" Foreground="{StaticResource Text}"
                  FontSize="11" FontFamily="{StaticResource Body}">
                <Menu.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Menu.ItemContainerStyle>
                <MenuItem Header="FILE">
                    <MenuItem Header="New Session" Command="{Binding AddSessionCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnMenuExit"/>
                </MenuItem>
                <MenuItem Header="VIEW">
                    <MenuItem Header="CV Builder"      Command="{Binding ToggleCvBuilderCommand}"/>
                    <MenuItem Header="Make CV Script"  Click="OnOpenScriptCreator"/>
                </MenuItem>
                <MenuItem Header="PLUGINS">
                    <MenuItem Header="OpenCV Capture" IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="Video Display"  IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="CV Python"      IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="Device Monitor" IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="Titan Bridge"   IsCheckable="True" IsChecked="{Binding IsTitanConnected, Mode=OneWay}"/>
                    <MenuItem Header="Output Panel"   IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="File Explorer"  IsCheckable="True" IsChecked="True"/>
                    <MenuItem Header="GPC3"           IsCheckable="True" IsChecked="{Binding IsGpcAvailable, Mode=OneWay}"/>
                </MenuItem>
                <MenuItem Header="HELP">
                    <MenuItem Header="About Labs Vision v2.0"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- ============================================================ -->
        <!--                  ROW 1 — COMMAND BAR                          -->
        <!-- ============================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource Bg}"
                BorderBrush="{StaticResource Hairline}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand block -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource Accent}" Width="3" Height="32"
                            Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="9"
                                   Foreground="{StaticResource Accent}">
                            <Run Text="◆ "/><Run Text="TM LABS"/>
                        </TextBlock>
                        <TextBlock Text="Labs Vision"
                                   FontFamily="{StaticResource Display}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Text}"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right cluster: device chips + actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- TITAN chip -->
                    <Border BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="10,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Faint}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTitanConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Accent}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Style="{StaticResource Eyebrow}" Text="TITAN " VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource Value}" Text="{Binding TitanDeviceName}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- GPC3 chip -->
                    <Border BorderBrush="{StaticResource Hairline}" BorderThickness="1" Padding="10,6" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Faint}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGpcAvailable}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Accent}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Style="{StaticResource Eyebrow}" Text="GPC3 " VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource Value}" Text="READY" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Mute -->
                    <Button Command="{Binding ToggleMuteCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,0"
                            ToolTip="Mute/unmute audio from all sessions">
                        <Button.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource Ghost}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAllMuted}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Danger}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding MuteButtonIcon}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding MuteButtonLabel}"/>
                        </StackPanel>
                    </Button>

                    <!-- Make CV -->
                    <Button Content="✏  MAKE CV" Style="{StaticResource Ghost}" Click="OnOpenScriptCreator" Margin="0,0,8,0"/>

                    <!-- New session (primary) -->
                    <Button Content="+  NEW SESSION" Style="{StaticResource AccentBtn}" Command="{Binding AddSessionCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!--                  ROW 2 — MAIN 3-COLUMN BODY                   -->
        <!-- ============================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="320" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- LEFT RAIL — SESSIONS + FILE EXPLORER                       -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Hairline}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Sessions header -->
                        <RowDefinition Height="*"/>      <!-- Sessions list -->
                        <RowDefinition Height="Auto"/>   <!-- Files header -->
                        <RowDefinition Height="2*"/>     <!-- Files list -->
                    </Grid.RowDefinitions>

                    <!-- ═══ Sessions header ═══ -->
                    <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource Eyebrow}" Text="SESSIONS  "/>
                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}">
                                    <Run Text="["/><Run Text="{Binding ActiveCount, Mode=OneWay}"/><Run Text="/10]"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="+" Style="{StaticResource Icon}"
                                    FontSize="14" FontWeight="Bold"
                                    Foreground="{StaticResource Accent}"
                                    Command="{Binding AddSessionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- ═══ Sessions list ═══ -->
                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Slots}"
                                 SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource PlainListItem}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0"
                                            Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#FF152035"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Height="62" Margin="16,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{Binding StatusColor}" Margin="0,12"/>
                                            <StackPanel Grid.Column="1" Margin="14,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}"
                                                           FontFamily="{StaticResource Display}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToStr}}"
                                                               FontFamily="{StaticResource Mono}" FontSize="9"
                                                               Foreground="{StaticResource Muted}"/>
                                                    <TextBlock Text="  ·  "
                                                               FontFamily="{StaticResource Mono}" FontSize="9"
                                                               Foreground="{StaticResource Faint}"
                                                               Visibility="{Binding ActiveScriptName, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding ActiveScriptName}"
                                                               FontFamily="{StaticResource Mono}" FontSize="9"
                                                               Foreground="{StaticResource Accent}"
                                                               Visibility="{Binding ActiveScriptName, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="✕" Style="{StaticResource Icon}"
                                                    Command="{Binding RemoveCommand}"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Remove session"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    Visibility="{Binding ActiveCount, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <TextBlock Text="◯" FontFamily="{StaticResource Mono}" FontSize="40"
                                       Foreground="{StaticResource Hairline}" HorizontalAlignment="Center"/>
                            <TextBlock Text="NO SESSIONS"
                                       Style="{StaticResource Eyebrow}"
                                       Margin="0,12,0,4" HorizontalAlignment="Center"/>
                            <TextBlock Text="Press + to spin one up"
                                       FontFamily="{StaticResource Body}" FontSize="11"
                                       Foreground="{StaticResource Faint}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- ═══ Files header ═══ -->
                    <Border Grid.Row="2" Style="{StaticResource PanelHeader}"
                            BorderThickness="0,1,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Eyebrow}" Text="FILE EXPLORER  "/>
                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource Faint}">
                                <Run Text="["/><Run Text="{Binding ScriptCount, Mode=OneWay}"/><Run Text="]"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Files list ═══ -->
                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding SelectedSession.AvailableScripts}"
                             SelectedItem="{Binding SelectedSession.SelectedScriptPath, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ScriptItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◦  " Foreground="{StaticResource Faint}"/>
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- LEFT SPLITTER                                              -->
            <!-- ════════════════════════════════════════════════════════ -->
            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                          Background="{StaticResource Hairline}"/>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- CENTER — VIDEO DISPLAY + OUTPUT                            -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Grid Grid.Column="2" Background="{StaticResource Bg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header -->
                    <RowDefinition Height="*"/>      <!-- Feed grid -->
                    <RowDefinition Height="Auto"/>   <!-- Splitter -->
                    <RowDefinition Height="200"/>    <!-- Output -->
                </Grid.RowDefinitions>

                <!-- ═══ Feed header ═══ -->
                <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource Eyebrow}" Text="◆ LIVE / SESSION FEED"
                                       Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="    "/>
                            <TextBlock Text="{Binding SelectedSession.SessionName}"
                                       FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{StaticResource Text}"/>
                            <TextBlock Text="    "/>
                            <TextBlock Text="{Binding SelectedSession.Status, Converter={StaticResource StatusToStr}}"
                                       FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{StaticResource Muted}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Feed grid ═══ -->
                <Grid Grid.Row="1" Background="{StaticResource Bg}">

                    <!-- Empty state with brand mark -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ActiveCount, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <Image Source="/Assets/tmlogo.png" Width="320" Margin="0,0,0,28"
                               RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.18"/>
                        <Border Background="{StaticResource Accent}" Width="32" Height="2"
                                HorizontalAlignment="Center" Margin="0,0,0,18"/>
                        <TextBlock Text="STANDING BY"
                                   Style="{StaticResource Eyebrow}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No active sessions"
                                   FontFamily="{StaticResource Display}" FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Press + NEW SESSION or Ctrl+N to launch a cloud window"
                                   FontFamily="{StaticResource Body}" FontSize="12"
                                   Foreground="{StaticResource Muted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Feed tiles -->
                    <ItemsControl x:Name="FeedGrid" ItemsSource="{Binding OccupiedSlots}" Margin="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding DataContext.GridColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" BorderBrush="{StaticResource Hairline}" BorderThickness="1">
                                    <views:FeedTileControl DataContext="{Binding}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- ═══ Splitter ═══ -->
                <GridSplitter Grid.Row="2" Height="1" HorizontalAlignment="Stretch"
                              Background="{StaticResource Hairline}"/>

                <!-- ═══ Output console ═══ -->
                <Grid Grid.Row="3" Background="{StaticResource SurfaceAlt}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource PanelHeader}"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource Eyebrow}" Text="OUTPUT  "/>
                                <TextBlock x:Name="OutputCountLabel" Text="WORKER LOG"
                                           Style="{StaticResource Eyebrow}"
                                           Foreground="{StaticResource Faint}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="CLEAR" Style="{StaticResource Icon}"
                                    Click="OnClearOutput" Padding="10,4"/>
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="OutputScroller" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,12,20,16">
                        <TextBlock x:Name="OutputLog"
                                   Foreground="{StaticResource Muted}"
                                   FontFamily="{StaticResource Mono}"
                                   FontSize="11"
                                   LineHeight="18"
                                   TextWrapping="Wrap"
                                   Text="◆ Labs Vision v2.0 ready · capture · cv · gpc3 · titan"/>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- RIGHT SPLITTER                                             -->
            <!-- ════════════════════════════════════════════════════════ -->
            <GridSplitter Grid.Column="3" Width="1" HorizontalAlignment="Center"
                          Background="{StaticResource Hairline}"/>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- RIGHT RAIL — CV PYTHON + DEVICE TELEMETRY                  -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Border Grid.Column="4"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Hairline}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- ═══ CV PYTHON ═══ -->
                        <Border Style="{StaticResource PanelHeader}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource Eyebrow}" Text="CV PYTHON  "/>
                                <TextBlock Text="{Binding SelectedSession.ActiveScriptName}"
                                           FontFamily="{StaticResource Mono}" FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Margin="20,18,20,22">
                            <TextBlock Style="{StaticResource Label}" Text="ACTIVE SCRIPT" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding SelectedSession.AvailableScripts}"
                                      SelectedItem="{Binding SelectedSession.SelectedScriptPath, Mode=TwoWay}"
                                      DropDownOpened="OnRowScriptDropDownOpened"
                                      Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource AccentBtn}"
                                        Content="▶  RUN" Margin="0,0,4,0"
                                        Command="{Binding SelectedSession.StartScriptCommand}"/>
                                <Button Grid.Column="1" Style="{StaticResource Ghost}"
                                        Content="■  STOP" Margin="4,0,0,0"
                                        Command="{Binding SelectedSession.StopScriptCommand}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource Label}" Text="STATUS  "/>
                                <TextBlock Text="{Binding SelectedSession.Status, Converter={StaticResource StatusToStr}, Mode=OneWay}"
                                           FontFamily="{StaticResource Mono}" FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ═══ OPENCV CAPTURE ═══ -->
                        <Border Style="{StaticResource PanelHeader}" BorderThickness="0,1,0,1">
                            <TextBlock Style="{StaticResource Eyebrow}" Text="OPENCV CAPTURE"/>
                        </Border>
                        <Grid Margin="20,16,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="SOURCE"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}" Text="DirectShow / OpenCV"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="RES"    Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}" Text="1920×1080" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Label}" Text="FPS"    Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Value}" Text="120"      Margin="0,6,0,0"/>
                        </Grid>

                        <!-- ═══ TITAN BRIDGE ═══ -->
                        <Border Style="{StaticResource PanelHeader}" BorderThickness="0,1,0,1">
                            <TextBlock Style="{StaticResource Eyebrow}" Text="TITAN BRIDGE"/>
                        </Border>
                        <Grid Margin="20,16,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="DEVICE"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}"
                                       Text="{Binding TitanDeviceName}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="GPC3"  Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}" Text="AVAILABLE"
                                       Foreground="{StaticResource Accent}" Margin="0,6,0,0"/>
                        </Grid>

                        <!-- ═══ DEVICE MONITOR ═══ -->
                        <Border Style="{StaticResource PanelHeader}" BorderThickness="0,1,0,1">
                            <TextBlock Style="{StaticResource Eyebrow}" Text="DEVICE MONITOR"/>
                        </Border>
                        <Grid Margin="20,16,20,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="VIGEM"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}" Text="CONNECTED"
                                       Foreground="{StaticResource Accent}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="TITAN" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}"
                                       Text="{Binding TitanDeviceName}" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Label}" Text="GPC3"  Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Value}" Text="AVAILABLE"
                                       Foreground="{StaticResource Accent}" Margin="0,6,0,0"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ============================================================ -->
        <!--                  ROW 3 — STATUS STRIP                         -->
        <!-- ============================================================ -->
        <Border Grid.Row="3"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Hairline}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Live indicator + version -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Style="{StaticResource Eyebrow}" Foreground="{StaticResource Text}" Text="READY"/>
                    <TextBlock Style="{StaticResource Eyebrow}" Text="    /    "/>
                    <TextBlock Style="{StaticResource Eyebrow}" Text="LABS VISION v2.0"/>
                </StackPanel>

                <!-- Telemetry -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Label}" Text="SESSIONS "/>
                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource Text}" Text="{Binding ActiveCount, Mode=OneWay}"/>
                    <TextBlock Style="{StaticResource Label}" Text="    SCRIPTS "/>
                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource Text}" Text="{Binding ScriptCount, Mode=OneWay}"/>
                    <TextBlock Style="{StaticResource Label}" Text="    CAPTURE 1920×1080@120  "/>
                    <TextBlock Style="{StaticResource Label}" Text="    TITAN "/>
                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="10"
                               Foreground="{StaticResource Accent}" Text="{Binding TitanDeviceName, Mode=OneWay}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
