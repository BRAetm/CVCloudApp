<Window x:Class="LabsVision.Core.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CVCloud Session"
        Width="500" Height="355"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Black">

    <Grid>
        <!-- Thin drag handle -->
        <Border Height="6" VerticalAlignment="Top" Background="#1A1A1A"
                Cursor="SizeAll" Panel.ZIndex="1"
                MouseLeftButtonDown="OnDragBar"/>

        <!-- WebView2 fills everything -->
        <wv2:WebView2 x:Name="WebView" Margin="0,6,0,0"/>
    </Grid>
</Window>
