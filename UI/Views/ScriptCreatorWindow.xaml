<Window x:Class="CVCloudApp.UI.Views.ScriptCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TM Labs — Script Creator"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Image viewer with drawing -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#0D1525" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Load Screenshot" Click="OnLoadImage" Cursor="Hand"
                            Foreground="#42A5F5" Background="Transparent" BorderThickness="0"
                            Padding="10,4" FontSize="11"/>
                    <Border Width="1" Background="#152240" Margin="6,4"/>
                    <Button Content="Clear All Regions" Click="OnClearRegions" Cursor="Hand"
                            Foreground="#EF5350" Background="Transparent" BorderThickness="0"
                            Padding="10,4" FontSize="11"/>
                    <Border Width="1" Background="#152240" Margin="6,4"/>
                    <TextBlock x:Name="InstructionText" Text="Load a screenshot, then click and drag to mark detection regions"
                               Foreground="#4A6A8A" FontSize="10" VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
            </Border>

            <!-- Canvas for image + drawing -->
            <Border Grid.Row="1" Background="#060A14" Margin="4" CornerRadius="6" ClipToBounds="True">
                <Canvas x:Name="DrawCanvas"
                        MouseLeftButtonDown="OnCanvasMouseDown"
                        MouseMove="OnCanvasMouseMove"
                        MouseLeftButtonUp="OnCanvasMouseUp"
                        Background="Transparent">
                    <Image x:Name="ScreenshotImage" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Drawing rectangles are added programmatically -->
                </Canvas>
            </Border>

            <!-- Status -->
            <Border Grid.Row="2" Background="#0D1525">
                <TextBlock x:Name="StatusText" Text="No image loaded" Foreground="#4A6A8A"
                           FontSize="10" Margin="8,0" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Right: Regions panel + Generate -->
        <Grid Grid.Column="1" Background="#0C1220">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0D1525" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="SCRIPT CREATOR" Foreground="#42A5F5" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Draw boxes around what you want to detect" Foreground="#4A6A8A" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Regions list -->
            <DockPanel Grid.Row="1">
                <Border DockPanel.Dock="Top" Background="#0D1525" Padding="10,6">
                    <TextBlock Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold">
                        <Run Text="REGIONS — "/><Run x:Name="RegionCountText" Text="0"/>
                    </TextBlock>
                </Border>
                <ListBox x:Name="RegionsList" Background="#0C1220" BorderThickness="0"
                         Foreground="#C8D6E5" FontSize="11" Padding="4"
                         SelectionChanged="OnRegionSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4"
                                        Background="#111B2E" Margin="0,0,8,0">
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                             BorderThickness="1" Padding="4,2" FontSize="10"/>
                                    <TextBlock Text="{Binding SizeText}" Foreground="#4A6A8A" FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#x2715;" Foreground="#EF5350" FontSize="9"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="OnDeleteRegion" Tag="{Binding}" VerticalAlignment="Top"
                                        Padding="4,2"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Script name -->
            <Border Grid.Row="2" Background="#0D1525" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="SCRIPT NAME" Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="ScriptNameBox" Text="my_detection"
                             Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                             BorderThickness="1" Padding="8,6" FontSize="12">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="Action when detected:" Foreground="#4A6A8A" FontSize="10" Margin="0,8,0,4"/>
                    <ComboBox x:Name="ActionCombo" SelectedIndex="0"
                              Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050" Padding="6,4">
                        <ComboBoxItem Content="Press A button"/>
                        <ComboBoxItem Content="Press X button"/>
                        <ComboBoxItem Content="Walk toward it (left stick)"/>
                        <ComboBoxItem Content="Visual only (no input)"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Generate button -->
            <Border Grid.Row="3" Padding="10,10">
                <Button Click="OnGenerate" Cursor="Hand" Height="44">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0D47A1" Offset="0"/>
                                        <GradientStop Color="#1565C0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="Generate Script" Foreground="White" FontWeight="SemiBold"
                                           FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1565C0" Offset="0"/>
                                                <GradientStop Color="#1976D2" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Grid>
</Window>
