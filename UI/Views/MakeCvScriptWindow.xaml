<Window x:Class="CVCloudApp.UI.Views.MakeCvScriptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TM Labs — CV Script Builder"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- LEFT: Image viewer with drawing / annotation                     -->
        <!-- ================================================================ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#0D1525" Padding="6,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Capture from live feed -->
                    <Button Content="&#xE722; Capture Feed" Click="OnCaptureFeed" Cursor="Hand"
                            Foreground="#00E676" Background="Transparent" BorderThickness="0"
                            Padding="10,4" FontSize="11" FontWeight="SemiBold"
                            ToolTip="Grab a screenshot from the active session feed"/>
                    <Border Width="1" Background="#152240" Margin="6,4"/>

                    <!-- Load from file -->
                    <Button Content="Load File" Click="OnLoadImage" Cursor="Hand"
                            Foreground="#42A5F5" Background="Transparent" BorderThickness="0"
                            Padding="10,4" FontSize="11"/>
                    <Border Width="1" Background="#152240" Margin="6,4"/>

                    <!-- Drawing tools -->
                    <TextBlock Text="Tool:" Foreground="#4A6A8A" FontSize="10"
                               VerticalAlignment="Center" Margin="4,0,6,0"/>
                    <RadioButton x:Name="ToolRegion" Content="Region" GroupName="DrawTool"
                                 IsChecked="True" Foreground="#C8D6E5" FontSize="10"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="Draw detection regions (boxes)"/>
                    <RadioButton x:Name="ToolColorPicker" Content="Color Picker" GroupName="DrawTool"
                                 Foreground="#FF9800" FontSize="10"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="Click to sample a color and create HSV range detection"/>
                    <RadioButton x:Name="ToolPixelSampler" Content="Pixel Sampler" GroupName="DrawTool"
                                 Foreground="#CE93D8" FontSize="10"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="Click to record pixel position and expected color"/>
                    <RadioButton x:Name="ToolHighlight" Content="Highlight" GroupName="DrawTool"
                                 Foreground="#FFD740" FontSize="10"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="Highlight errors / areas of interest"/>
                    <RadioButton x:Name="ToolArrow" Content="Arrow" GroupName="DrawTool"
                                 Foreground="#FF5252" FontSize="10"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="Draw arrows pointing to something"/>
                    <RadioButton x:Name="ToolFreehand" Content="Freehand" GroupName="DrawTool"
                                 Foreground="#E040FB" FontSize="10"
                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                 ToolTip="Freehand draw / circle things"/>
                    <Border Width="1" Background="#152240" Margin="6,4"/>

                    <Button Content="Clear All" Click="OnClearAll" Cursor="Hand"
                            Foreground="#EF5350" Background="Transparent" BorderThickness="0"
                            Padding="10,4" FontSize="11"/>
                    <Border Width="1" Background="#152240" Margin="6,4"/>

                    <TextBlock x:Name="InstructionText"
                               Text="Capture a feed, load a file, or paste an image (Ctrl+V / drag-drop)"
                               Foreground="#4A6A8A" FontSize="10" VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
            </Border>

            <!-- Canvas for image + drawing -->
            <Border Grid.Row="1" Background="#060A14" Margin="4" CornerRadius="6" ClipToBounds="True">
                <Canvas x:Name="DrawCanvas"
                        MouseLeftButtonDown="OnCanvasMouseDown"
                        MouseMove="OnCanvasMouseMove"
                        MouseLeftButtonUp="OnCanvasMouseUp"
                        Background="Transparent"
                        SizeChanged="OnCanvasSizeChanged">
                    <Image x:Name="ScreenshotImage" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Canvas>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#0D1525">
                <TextBlock x:Name="StatusText" Text="No image loaded" Foreground="#4A6A8A"
                           FontSize="10" Margin="8,0" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ================================================================ -->
        <!-- CENTER: Rule Builder — Detections + Actions                      -->
        <!-- ================================================================ -->
        <Grid Grid.Column="1" Background="#0C1220">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0D1525" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="CV SCRIPT BUILDER" Foreground="#42A5F5" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Build detection rules visually"
                               Foreground="#4A6A8A" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Detections list -->
            <DockPanel Grid.Row="1">
                <Border DockPanel.Dock="Top" Background="#0D1525" Padding="10,6">
                    <TextBlock Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold">
                        <Run Text="DETECTIONS &#x2014; "/>
                        <Run x:Name="RegionCountText" Text="0"/>
                    </TextBlock>
                </Border>
                <ListBox x:Name="RegionsList" Background="#0C1220" BorderThickness="0"
                         Foreground="#C8D6E5" FontSize="11" Padding="4"
                         SelectionChanged="OnRegionSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4"
                                        Background="#111B2E" Margin="0,0,8,0">
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                             BorderThickness="1" Padding="4,2" FontSize="10"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding DetectionTypeLabel}" FontSize="9" Margin="0,0,6,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#42A5F5"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding SizeText}" Foreground="#4A6A8A" FontSize="9"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#x2715;" Foreground="#EF5350" FontSize="9"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="OnDeleteRegion" Tag="{Binding}" VerticalAlignment="Top"
                                        Padding="4,2"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Add Detection buttons -->
            <Border Grid.Row="2" Padding="8,6">
                <StackPanel>
                    <Button Content="+ Template Region" Click="OnAddTemplateRegion" Cursor="Hand"
                            Foreground="White" FontSize="10" FontWeight="SemiBold" Height="28" Margin="0,0,0,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" Background="#1565C0" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1976D2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="+ Color Range" Click="OnAddColorRange" Cursor="Hand"
                                Foreground="White" FontSize="10" FontWeight="SemiBold" Height="28" Margin="0,0,2,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="6" Background="#E65100" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F57C00"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="1" Content="+ Pixel Check" Click="OnAddPixelCheck" Cursor="Hand"
                                Foreground="White" FontSize="10" FontWeight="SemiBold" Height="28" Margin="2,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="6" Background="#6A1B9A" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#8E24AA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions list -->
            <DockPanel Grid.Row="3" MaxHeight="180">
                <Border DockPanel.Dock="Top" Background="#0D1525" Padding="10,6">
                    <TextBlock Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold">
                        <Run Text="ACTIONS &#x2014; "/>
                        <Run x:Name="ActionCountText" Text="0"/>
                    </TextBlock>
                </Border>
                <ListBox x:Name="ActionsList" Background="#0C1220" BorderThickness="0"
                         Foreground="#C8D6E5" FontSize="11" Padding="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#42A5F5"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayText}" Foreground="#C8D6E5" FontSize="10"/>
                                    <TextBlock Text="{Binding Type}" Foreground="#4A6A8A" FontSize="8"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#x2715;" Foreground="#EF5350" FontSize="9"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Click="OnDeleteAction" Tag="{Binding}" VerticalAlignment="Top"
                                        Padding="4,2"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Add Action buttons -->
            <Border Grid.Row="4" Padding="8,6">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ButtonPickerCombo" Grid.Column="0" FontSize="10"
                                  Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                  Padding="4,3" Margin="0,0,4,0">
                            <ComboBoxItem Content="A" IsSelected="True"/>
                            <ComboBoxItem Content="B"/>
                            <ComboBoxItem Content="X"/>
                            <ComboBoxItem Content="Y"/>
                            <ComboBoxItem Content="LB"/>
                            <ComboBoxItem Content="RB"/>
                            <ComboBoxItem Content="LT"/>
                            <ComboBoxItem Content="RT"/>
                            <ComboBoxItem Content="DPad Up"/>
                            <ComboBoxItem Content="DPad Down"/>
                            <ComboBoxItem Content="DPad Left"/>
                            <ComboBoxItem Content="DPad Right"/>
                            <ComboBoxItem Content="Start"/>
                            <ComboBoxItem Content="Select"/>
                        </ComboBox>
                        <Button Grid.Column="1" Content="+ Press" Click="OnAddPressButton" Cursor="Hand"
                                Foreground="#42A5F5" Background="Transparent" BorderBrush="#1E3050"
                                BorderThickness="1" Padding="8,3" FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="StickPickerCombo" Grid.Column="0" FontSize="10"
                                  Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                  Padding="4,3" Margin="0,0,4,0">
                            <ComboBoxItem Content="Left Stick Up" IsSelected="True"/>
                            <ComboBoxItem Content="Left Stick Down"/>
                            <ComboBoxItem Content="Left Stick Left"/>
                            <ComboBoxItem Content="Left Stick Right"/>
                            <ComboBoxItem Content="Right Stick Up"/>
                            <ComboBoxItem Content="Right Stick Down"/>
                            <ComboBoxItem Content="Right Stick Left"/>
                            <ComboBoxItem Content="Right Stick Right"/>
                        </ComboBox>
                        <Button Grid.Column="1" Content="+ Stick" Click="OnAddMoveStick" Cursor="Hand"
                                Foreground="#42A5F5" Background="Transparent" BorderBrush="#1E3050"
                                BorderThickness="1" Padding="8,3" FontSize="10"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="+ Wait 500ms" Click="OnAddWait" Cursor="Hand"
                                Foreground="#42A5F5" Background="Transparent" BorderBrush="#1E3050"
                                BorderThickness="1" Padding="6,3" FontSize="10" Margin="0,0,2,0"/>
                        <Button Grid.Column="1" Content="+ Emit Gamepad" Click="OnAddEmitGamepad" Cursor="Hand"
                                Foreground="#42A5F5" Background="Transparent" BorderBrush="#1E3050"
                                BorderThickness="1" Padding="6,3" FontSize="10" Margin="2,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================================================================ -->
        <!-- RIGHT: Script Config + Output                                    -->
        <!-- ================================================================ -->
        <Grid Grid.Column="2" Background="#0C1220">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Script Config header -->
            <Border Grid.Row="0" Background="#0D1525" Padding="10,8">
                <TextBlock Text="SCRIPT CONFIG" Foreground="#42A5F5" FontSize="13" FontWeight="SemiBold"/>
            </Border>

            <!-- Config fields -->
            <Border Grid.Row="1" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="SCRIPT NAME" Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="ScriptNameBox" Text="my_cv_script"
                             Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                             BorderThickness="1" Padding="8,6" FontSize="12">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="SAVE FOLDER" Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse" Click="OnBrowseFolder" Cursor="Hand"
                                Foreground="#42A5F5" Background="Transparent" BorderThickness="0"
                                Padding="8,4" FontSize="10"/>
                        <TextBox x:Name="SaveFolderBox"
                                 Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                 BorderThickness="1" Padding="6,4" FontSize="10" IsReadOnly="True">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                    </DockPanel>

                    <TextBlock Text="CAPTURE MODE" Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <ComboBox x:Name="CaptureModeCombo" FontSize="10"
                              Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                              Padding="4,3">
                        <ComboBoxItem Content="Direct (dxcam)" IsSelected="True"/>
                        <ComboBoxItem Content="ZMQ Pipeline"/>
                        <ComboBoxItem Content="Screen Region"/>
                    </ComboBox>

                    <TextBlock Text="MATCH THRESHOLD" Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <DockPanel>
                        <TextBlock x:Name="ThresholdValueText" DockPanel.Dock="Right" Text="0.70"
                                   Foreground="#C8D6E5" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="30"/>
                        <Slider x:Name="ThresholdSlider" Minimum="0.5" Maximum="1.0" Value="0.70"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                ValueChanged="OnThresholdChanged"
                                Foreground="#42A5F5"/>
                    </DockPanel>

                    <TextBlock Text="FPS TARGET" Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <DockPanel>
                        <TextBlock x:Name="FpsValueText" DockPanel.Dock="Right" Text="60"
                                   Foreground="#C8D6E5" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="24"/>
                        <Slider x:Name="FpsSlider" Minimum="1" Maximum="120" Value="60"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnFpsChanged"
                                Foreground="#42A5F5"/>
                    </DockPanel>

                    <!-- Checkboxes -->
                    <CheckBox x:Name="ChkDirectCapture" Content="DIRECT_CAPTURE" IsChecked="True"
                              Foreground="#C8D6E5" FontSize="10" Margin="0,8,0,0"/>
                    <CheckBox x:Name="ChkDrawOverlay" Content="Draw overlay on frame" IsChecked="True"
                              Foreground="#C8D6E5" FontSize="10" Margin="0,4,0,0"/>
                    <CheckBox x:Name="ChkMultiScale" Content="Multi-scale matching (0.5x-1.5x)" IsChecked="True"
                              Foreground="#C8D6E5" FontSize="10" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Rule Logic -->
            <DockPanel Grid.Row="2">
                <Border DockPanel.Dock="Top" Background="#0D1525" Padding="10,6">
                    <TextBlock Foreground="#4A6A8A" FontSize="10" FontWeight="SemiBold">
                        <Run Text="RULE LOGIC &#x2014; "/>
                        <Run x:Name="RuleCountText" Text="0"/>
                    </TextBlock>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0C1220">
                    <StackPanel>
                        <ListBox x:Name="RulesList" Background="#0C1220" BorderThickness="0"
                                 Foreground="#C8D6E5" FontSize="10" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0D1525" CornerRadius="4" Padding="6,4" Margin="0,2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="IF " Foreground="#FF9800" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                                                <ComboBox x:Name="RuleDetectionCombo" FontSize="9"
                                                          Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                                          Padding="3,1" MinWidth="80"
                                                          ItemsSource="{Binding DetectionNames}"
                                                          SelectedItem="{Binding DetectionName, Mode=TwoWay}"
                                                          Tag="{Binding}"/>
                                                <TextBlock Text=" conf &#x2265; " Foreground="#4A6A8A" FontSize="9" VerticalAlignment="Center"/>
                                                <TextBox Text="{Binding ConfidenceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                                         BorderThickness="1" Padding="3,1" FontSize="9" Width="36"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="THEN " Foreground="#00E676" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center"/>
                                                <ComboBox FontSize="9"
                                                          Background="#111B2E" Foreground="#C8D6E5" BorderBrush="#1E3050"
                                                          Padding="3,1" MinWidth="80"
                                                          ItemsSource="{Binding ActionNames}"
                                                          SelectedItem="{Binding ActionName, Mode=TwoWay}"
                                                          Tag="{Binding}"/>
                                            </StackPanel>
                                            <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                    Content="&#x2715;" Foreground="#EF5350" FontSize="9"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Click="OnDeleteRule" Tag="{Binding}"
                                                    VerticalAlignment="Center" Padding="4,2"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="+ Add Rule" Click="OnAddRule" Cursor="Hand"
                                Foreground="#42A5F5" Background="Transparent" BorderBrush="#1E3050"
                                BorderThickness="1" Padding="8,4" FontSize="10" Margin="8,4,8,4"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- Action buttons -->
            <Border Grid.Row="3" Padding="10,8">
                <StackPanel>
                    <!-- Save screenshot button -->
                    <Button Click="OnSaveScreenshot" Cursor="Hand" Height="34" Margin="0,0,0,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2E7D32" Offset="0"/>
                                            <GradientStop Color="#388E3C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Save Annotated Screenshot" Foreground="White" FontWeight="SemiBold"
                                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#388E3C" Offset="0"/>
                                                    <GradientStop Color="#43A047" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Generate script button -->
                    <Button Click="OnManualGenerate" Cursor="Hand" Height="34" Margin="0,0,0,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0D47A1" Offset="0"/>
                                            <GradientStop Color="#1565C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Generate Script" Foreground="White" FontWeight="SemiBold"
                                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#1565C0" Offset="0"/>
                                                    <GradientStop Color="#1976D2" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Test against frame button -->
                    <Button Click="OnTestAgainstFrame" Cursor="Hand" Height="34">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00695C" Offset="0"/>
