<UserControl x:Class="CVCloudApp.UI.Views.FeedTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CVCloudApp.UI.Converters"
             MouseLeftButtonDown="OnTileClicked"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             Cursor="Hand">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border ClipToBounds="True">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="BorderBrush" Value="#1E1B30"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="#0C0A14"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="#7C3AED"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                        <Setter Property="Background" Value="#0A0910"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- ═══ EMPTY SLOT ═══ -->
            <Border Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E0C18" Offset="0"/>
                        <GradientStop Color="#0A0812" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SlotLabel}"
                               Foreground="#16142E"
                               FontSize="56"
                               FontWeight="ExtraBold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="EMPTY"
                               Foreground="#16142E"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,-4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ═══ OCCUPIED SLOT ═══ -->
            <Grid Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header bar -->
                <Border Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0E0C18" Offset="0"/>
                            <GradientStop Color="#100E1C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="10,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Session number badge -->
                            <Border CornerRadius="4" Padding="5,1" Margin="0,0,6,0"
                                    Background="#1A1730">
                                <TextBlock Text="{Binding SlotLabel}"
                                           Foreground="#A78BFA"
                                           FontSize="10" FontWeight="Bold"
                                           FontFamily="Segoe UI"/>
                            </Border>
                            <TextBlock Text="{Binding SessionName}"
                                       Foreground="#D0CCE8"
                                       FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Status indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Grid Margin="0,0,2,0">
                                <Ellipse Width="10" Height="10" Opacity="0.25"
                                         Fill="{Binding StatusColor}"/>
                                <Ellipse Width="6" Height="6"
                                         Fill="{Binding StatusColor}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Thin separator -->
                <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1E1B30" Offset="0"/>
                            <GradientStop Color="#14122A" Offset="0.5"/>
                            <GradientStop Color="#1E1B30" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- WebView2 container -->
                <Grid Grid.Row="1" x:Name="WebViewContainer" Background="#08070E">
                    <StackPanel x:Name="WaitingPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,0,8"
                                Background="#0E0C18">
                            <TextBlock Text="&#x1F3AE;" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Connecting..."
                                   Foreground="#3D3860"
                                   FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Footer: script name (only visible when running) -->
                <Border Grid.Row="2" Padding="10,4"
                        Visibility="{Binding ActiveScriptName, Converter={StaticResource BoolToVis}}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0E0C18" Offset="0"/>
                            <GradientStop Color="#100E1C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="3" Padding="4,1" Background="#1A2E1A" Margin="0,0,6,0">
                            <TextBlock Text="LIVE" Foreground="#34D399" FontSize="8"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="{Binding ActiveScriptName}"
                                   Foreground="#C084FC"
                                   FontSize="10"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
